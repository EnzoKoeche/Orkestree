DATABASE_URL="postgresql://postgres:postgres@localhost:5432/orkestree?schema=public"
REDIS_URL="redis://localhost:6379"

# ── Auth ─────────────────────────────────────────────────────────────────────
# Signing key for the access token issued by POST /auth/login.
# Must be at least 16 characters; the app refuses to boot otherwise.
# Generate with: `openssl rand -hex 32`
JWT_SECRET="change-this-to-a-secure-random-secret"
# zeit/ms format. Default 7 days. Shorten in production if your refresh story
# tolerates it (no refresh-token endpoint ships with this phase).
JWT_EXPIRES_IN="7d"

PORT=3000
NODE_ENV=development

# ── Rate limiting ────────────────────────────────────────────────────────────
# POST /auth/login is throttled to 5 attempts / 60s / IP via @nestjs/throttler.
# The global default (60/min) is permissive and only enforced as a backstop —
# tenant-scoped routes are NOT individually rate-limited at this stage. In
# multi-replica production, swap the default in-memory storage for the Redis-
# backed throttler store; tracked as a separate task in Notion.

# ── Seed (dev only) ──────────────────────────────────────────────────────────
# `pnpm --filter @orkestree/api seed` (or `pnpm prisma db seed`) seeds a
# deterministic owner + 2 companies for local end-to-end testing.
# Credentials are constants in prisma/seed.ts, intentionally NOT pulled from
# env so that `bash apps/api/scripts/smoke-auth.sh` can hard-code them.
