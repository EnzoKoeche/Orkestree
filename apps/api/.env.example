DATABASE_URL="postgresql://postgres:postgres@localhost:5432/orkestree?schema=public"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="change-this-to-a-secure-random-secret"
JWT_EXPIRES_IN="7d"
PORT=3000
NODE_ENV=development

# ── BullMQ / job runner ──────────────────────────────────────────────────────
# Cron expression governing how often the proposal-expiry job is scheduled.
# Default: every 5 minutes. Override per environment via process env.
# Cron is interpreted in UTC by BullMQ (no implicit local timezone).
PROPOSAL_EXPIRY_CRON="*/5 * * * *"
# Number of due proposals the worker will pick per batch. The DB query uses
# FOR UPDATE SKIP LOCKED, so multiple workers can run concurrently and split
# the backlog. Tune up for spiky workloads, down for tiny shared Postgres.
PROPOSAL_EXPIRY_BATCH_SIZE=50
