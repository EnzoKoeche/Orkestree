# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
.pnp/
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Build output ─────────────────────────────────────────────────────────────
dist/
build/
out/
.next/
.turbo/
*.tsbuildinfo
next-env.d.ts

# ── Test + coverage ──────────────────────────────────────────────────────────
coverage/
*.lcov
.nyc_output/

# ── Local env (NEVER commit secrets) ─────────────────────────────────────────
# Templates (.env.example) ARE committed; per-developer overrides are not.
.env
.env*.local
.env.development
.env.production
.env.test
!.env.example

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*

# ── OS noise ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor / IDE ─────────────────────────────────────────────────────────────
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/tasks.json
!.vscode/launch.json
*.swp
*.swo
*~

# ── Claude Code per-machine state ───────────────────────────────────────────
.claude/settings.local.json

# ── Misc ─────────────────────────────────────────────────────────────────────
*.pem
*.key
.cache/
