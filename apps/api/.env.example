DATABASE_URL="postgresql://postgres:postgres@localhost:5432/orkestree?schema=public"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="change-this-to-a-secure-random-secret"
JWT_EXPIRES_IN="7d"
PORT=3000
NODE_ENV=development

# ── BullMQ / job runner ──────────────────────────────────────────────────────
# Cron expression governing how often the proposal-expiry job is scheduled.
# Default: every 5 minutes. Override per environment via process env.
# Cron is interpreted in UTC by BullMQ (no implicit local timezone).
PROPOSAL_EXPIRY_CRON="*/5 * * * *"
# Number of due proposals the worker will pick per batch. The DB query uses
# FOR UPDATE SKIP LOCKED, so multiple workers can run concurrently and split
# the backlog. Tune up for spiky workloads, down for tiny shared Postgres.
PROPOSAL_EXPIRY_BATCH_SIZE=50

# ── Proposal PDF pipeline ────────────────────────────────────────────────────
# Master kill-switch. Set to "false" to skip enqueueing PDF jobs (e.g. CI
# without Puppeteer installed, low-memory dev pods).
PROPOSAL_PDF_ENABLED=true
# Per-process worker concurrency. Each in-flight job opens a Chromium page,
# so realistic ceilings are small. Operators scale horizontally instead.
PROPOSAL_PDF_CONCURRENCY=2
# Storage driver: "local" (filesystem, dev/CI) or "s3" (S3/R2/MinIO, prod).
PROPOSAL_PDF_STORAGE_DRIVER=local
# Local-driver settings. Files are written under PROPOSAL_PDF_LOCAL_DIR and
# served at PROPOSAL_PDF_PUBLIC_BASE_URL/<objectKey>.
PROPOSAL_PDF_LOCAL_DIR=./var/proposal-pdfs
PROPOSAL_PDF_PUBLIC_BASE_URL=/files
# S3-driver settings (only required when PROPOSAL_PDF_STORAGE_DRIVER=s3).
# PROPOSAL_PDF_S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# PROPOSAL_PDF_S3_REGION=auto
# PROPOSAL_PDF_S3_BUCKET=orkestree-proposal-pdfs
# PROPOSAL_PDF_S3_ACCESS_KEY=
# PROPOSAL_PDF_S3_SECRET_KEY=
# PROPOSAL_PDF_S3_PUBLIC_BASE_URL=https://cdn.example.com/proposal-pdfs
# PROPOSAL_PDF_S3_FORCE_PATH_STYLE=false
# Presigned-URL TTL (seconds) issued by GET /...:proposalId/pdf when the s3
# driver is active. The PDF is a confidential pricing document; keep this
# short. Default 300 (5 min); hard cap 3600 (1 h). Out-of-range values fall
# back to 300.
# PROPOSAL_PDF_S3_READ_TTL_SECONDS=300
# Puppeteer / Chromium launch overrides. Containerised environments without
# user-namespaces should set NO_SANDBOX=true; a custom Chromium binary path
# can be pinned via PUPPETEER_EXECUTABLE.
PROPOSAL_PDF_PUPPETEER_NO_SANDBOX=false
# PROPOSAL_PDF_PUPPETEER_EXECUTABLE=/usr/bin/chromium
