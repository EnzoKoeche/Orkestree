generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════════════════════════════════

enum Role {
  OWNER
  ADMIN
  FINANCEIRO
  OPERACIONAL
  CLIENTE
}

enum MembershipStatus {
  ACTIVE
  INACTIVE
  INVITED
}

enum ClientType {
  INDIVIDUAL
  BUSINESS
}

enum CustomFieldType {
  TEXT
  TEXTAREA
  NUMBER
  DECIMAL
  DATE
  DATETIME
  SELECT
  MULTISELECT
  BOOLEAN
  FILE
  PHONE
  EMAIL
  URL
}

enum CustomFieldTarget {
  REQUEST
  CLIENT
  PROPOSAL
  SERVICE_ORDER
  CONTACT
}

enum AssignmentType {
  ROLE
  USER
  ROUND_ROBIN
  MANUAL
}

enum PdfTemplateType {
  PROPOSAL
  INVOICE
  REPORT
  SERVICE_ORDER
}

enum TemplateEngine {
  HANDLEBARS
  BLOCKS
}

enum AutomationTrigger {
  REQUEST_CREATED
  STAGE_CHANGED
  PROPOSAL_SENT
  PROPOSAL_APPROVED
  PROPOSAL_REJECTED
  PAYMENT_RECEIVED
  PAYMENT_OVERDUE
  TASK_COMPLETED
  DOCUMENT_UPLOADED
}

enum AutomationActionType {
  SEND_EMAIL
  SEND_NOTIFICATION
  ASSIGN_USER
  CHANGE_STAGE
  CREATE_TASK
  GENERATE_DOCUMENT
  WEBHOOK
}

enum ConditionOperator {
  EQUALS
  NOT_EQUALS
  CONTAINS
  NOT_CONTAINS
  GREATER_THAN
  LESS_THAN
  GREATER_THAN_OR_EQUAL
  LESS_THAN_OR_EQUAL
  IS_NULL
  IS_NOT_NULL
  IN
  NOT_IN
}

enum CompanyResource {
  REQUEST
  CLIENT
  PROPOSAL
  FINANCIAL
  TASK
  DOCUMENT
  CHAT
  SETTINGS
  COMPANY_CONFIG
  USER_MANAGEMENT
  AUDIT_LOG
}

enum PermissionAction {
  VIEW
  CREATE
  EDIT
  DELETE
  APPROVE
  REJECT
  PUBLISH
  EXPORT
  ASSIGN
}

// Sensitive financial fields enforced by FieldFilterInterceptor.
// Resolution order: UserFieldPermissionOverride > RoleFieldPermission > FIELD_DEFAULTS
enum SensitiveField {
  INTERNAL_COST
  MARGIN
  SUPPLIER_PRICE
  GROSS_PROFIT
  NET_PROFIT
  PAYMENT_METHOD
  BANK_ACCOUNT
  FISCAL_KEY
}

enum AuditOperation {
  CREATE
  UPDATE
  DELETE
  ACTIVATE
  DEACTIVATE
  REORDER
  TRANSITION  // stage/status transition (ServiceRequest, Task)
  ASSIGN      // assignment change (ServiceRequest, Task)
  CANCEL      // cancellation (ServiceRequest, Task)
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum ProposalStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  EXPIRED
  CANCELLED
}

// ═══════════════════════════════════════════════════════════════════════════
// IDENTITY BOUNDED CONTEXT
// ═══════════════════════════════════════════════════════════════════════════

// Global user identity. Not tenant-scoped.
// Tenant-specific context lives in CompanyMembership.
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  avatarUrl    String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships             CompanyMembership[]
  configAuditLogs         ConfigAuditLog[]

  @@index([email])
}

model Company {
  id                   String   @id @default(cuid())
  legalName            String
  tradeName            String?
  taxId                String   @unique // CNPJ
  stateRegistration    String?
  municipalRegistration String?
  financialEmail       String
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  // Fiscal address (structured, not JSON)
  addressStreet     String
  addressNumber     String
  addressComplement String?
  addressNeighborhood String
  addressCity       String
  addressState      String  // 2-char state code
  addressPostalCode String
  addressCountry    String  @default("BR")

  memberships              CompanyMembership[]
  serviceTypes             ServiceType[]
  customFields             CustomField[]
  workflows                Workflow[]
  workflowStages           WorkflowStage[]
  stageTransitions         StageTransition[]
  stageAssigneeRules       StageAssigneeRule[]
  roundRobinCursors        RoundRobinCursor[]
  rolePermissions          RolePermission[]
  userPermissionOverrides  UserPermissionOverride[]
  roleFieldPermissions     RoleFieldPermission[]
  userFieldOverrides       UserFieldPermissionOverride[]
  configAuditLogs          ConfigAuditLog[]
  serviceRequests          ServiceRequest[]
  requestFieldValues       RequestFieldValue[]
  requestStageHistories    RequestStageHistory[]
  requestAssignments       RequestAssignment[]
  clients                  Client[]
  clientFieldValues        ClientFieldValue[]
  tasks                    Task[]
  taskComments             TaskComment[]
  proposals               Proposal[]
  proposalItems           ProposalItem[]
  proposalStatusHistories ProposalStatusHistory[]
  proposalFieldValues     ProposalFieldValue[]

  @@index([taxId])
}

// Tenant-scoped membership. This is the identity boundary per company.
// Permissions, assignments, and overrides reference this, not raw userId.
// When a user leaves and rejoins, a new membership is created.
// Old overrides are orphaned but safe — they will not match the new membership.
model CompanyMembership {
  id        String           @id @default(cuid())
  companyId String
  userId    String
  role      Role
  status    MembershipStatus @default(INVITED)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  stageAssigneeRules      StageAssigneeRule[]
  userPermissionOverrides UserPermissionOverride[]
  userFieldOverrides      UserFieldPermissionOverride[]
  roundRobinCursorsAsLast RoundRobinCursor[]
  requestsAsAssignee      ServiceRequest[]      @relation("RequestAssignee")
  requestsCreated         ServiceRequest[]      @relation("RequestCreator")
  stageHistoriesAsActor   RequestStageHistory[] @relation("StageHistoryActor")
  assignmentsAsTarget     RequestAssignment[]   @relation("AssignmentTarget")
  assignmentsAsActor      RequestAssignment[]   @relation("AssignmentActor")
  tasksAsAssignee                Task[]                @relation("TaskAssignee")
  tasksCreated                   Task[]                @relation("TaskCreator")
  taskComments                   TaskComment[]         @relation("TaskCommentAuthor")
  proposalsCreated               Proposal[]            @relation("ProposalCreator")
  proposalsApproved              Proposal[]            @relation("ProposalApprover")
  proposalsRejected              Proposal[]            @relation("ProposalRejector")
  proposalStatusHistoriesAsActor ProposalStatusHistory[] @relation("ProposalStatusHistoryActor")

  @@unique([companyId, userId])
  @@index([companyId])
  @@index([companyId, role])
  @@index([companyId, status])
  @@index([userId])
}

// ═══════════════════════════════════════════════════════════════════════════
// COMPANY-CONFIG BOUNDED CONTEXT
// ═══════════════════════════════════════════════════════════════════════════

// ── SERVICE TYPES ─────────────────────────────────────────────────────────
// workflowId is nullable: null → runtime-resolve to company's isDefault Workflow.
// Composite FK (companyId, workflowId) → Workflow(companyId, id) added via raw SQL.
// @@unique([companyId, id]) added via raw SQL (FK target for CustomField).

model ServiceType {
  id          String   @id @default(cuid())
  companyId   String
  code        String   // immutable after creation; referenced in automation conditions
  name        String   // mutable display name
  description String?
  workflowId  String?  // null → runtime-resolve default workflow
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company         Company          @relation(fields: [companyId], references: [id])
  workflow        Workflow?        @relation(fields: [workflowId], references: [id])
  customFields    CustomField[]
  serviceRequests ServiceRequest[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([companyId, isActive])
  // Raw SQL: UNIQUE ("companyId", "id") → FK target for CustomField and ServiceRequest
  // Raw SQL: FK (companyId, workflowId) → Workflow(companyId, id)
}

// ── CUSTOM FIELDS ─────────────────────────────────────────────────────────
// code: single stable machine-readable identifier (immutable).
// label: mutable display name.
// serviceTypeId: only meaningful when target = REQUEST.
// Composite FK (companyId, serviceTypeId) → ServiceType(companyId, id) added via raw SQL.

model CustomField {
  id            String            @id @default(cuid())
  companyId     String
  code          String            // immutable; referenced in automation dot-notation
  label         String            // mutable display name
  target        CustomFieldTarget
  serviceTypeId String?           // only set when target = REQUEST
  type          CustomFieldType
  isRequired    Boolean           @default(false)
  isActive      Boolean           @default(true)
  sortOrder     Int               @default(0)
  placeholder   String?
  helpText      String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  company            Company              @relation(fields: [companyId], references: [id])
  serviceType        ServiceType?         @relation(fields: [serviceTypeId], references: [id])
  options             CustomFieldOption[]
  requestFieldValues  RequestFieldValue[]
  clientFieldValues   ClientFieldValue[]
  proposalFieldValues ProposalFieldValue[]

  @@unique([companyId, code])
  @@index([companyId, target])
  @@index([companyId, target, serviceTypeId])
  @@index([companyId, isActive])
  // Raw SQL: UNIQUE ("companyId", "id") → FK target for RequestFieldValue and ClientFieldValue
  // Raw SQL: FK (companyId, serviceTypeId) → ServiceType(companyId, id)
}

model CustomFieldOption {
  id            String      @id @default(cuid())
  customFieldId String
  label         String      // mutable display name
  value         String      // immutable stable value; referenced in automation conditions
  sortOrder     Int         @default(0)

  customField CustomField @relation(fields: [customFieldId], references: [id], onDelete: Cascade)

  @@unique([customFieldId, value])
  @@index([customFieldId])
}

// ── WORKFLOWS ─────────────────────────────────────────────────────────────
// isDefault: exactly one per company. Enforced by partial unique index via raw SQL.
// Composite UNIQUE(companyId, id) added via raw SQL as FK target for WorkflowStage.
// Deferred: structuralVersion + WorkflowVersion snapshot for copy-on-write.

model Workflow {
  id          String   @id @default(cuid())
  companyId   String
  code        String   // immutable; unique per company
  name        String
  description String?
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company         Company           @relation(fields: [companyId], references: [id])
  stages          WorkflowStage[]
  transitions     StageTransition[]
  serviceTypes    ServiceType[]
  serviceRequests ServiceRequest[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([companyId, isDefault])
  // Raw SQL: UNIQUE ("companyId", "id") → FK target for WorkflowStage, StageTransition, ServiceRequest
  // Raw SQL: UNIQUE INDEX WHERE isDefault = true → exactly one default per company
}

// ── WORKFLOW STAGES ───────────────────────────────────────────────────────
// companyId: denormalized for direct tenant-isolation queries on hot read paths.
// Integrity: composite FK (companyId, workflowId) → Workflow(companyId, id) via raw SQL.
// isInitial: exactly one per workflow. Partial unique index via raw SQL.
// isFinal: no uniqueness constraint; multiple terminal stages are valid.
// UNIQUE(workflowId, id): FK target for StageTransition fromStageId/toStageId.
// UNIQUE(companyId, id): FK target for StageAssigneeRule.

model WorkflowStage {
  id          String   @id @default(cuid())
  companyId   String   // denormalized; composite FK enforces match with workflow.companyId
  workflowId  String
  code        String   // immutable; unique per workflow
  name        String
  description String?
  color       String?  // hex color for Kanban display
  sortOrder   Int
  isInitial   Boolean  @default(false) // exactly one per workflow — partial unique index
  isFinal     Boolean  @default(false) // multiple allowed (done, cancelled, rejected)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company                  Company              @relation(fields: [companyId], references: [id])
  workflow                 Workflow             @relation(fields: [workflowId], references: [id])
  assigneeRules            StageAssigneeRule[]
  outbound                 StageTransition[]    @relation("TransitionFrom")
  inbound                  StageTransition[]    @relation("TransitionTo")
  serviceRequestsAsCurrent ServiceRequest[]     @relation("ServiceRequestCurrentStage")
  stageHistoriesAsFrom     RequestStageHistory[] @relation("StageHistoryFrom")
  stageHistoriesAsTo       RequestStageHistory[] @relation("StageHistoryTo")

  @@unique([workflowId, code])
  @@unique([workflowId, id]) // FK target for StageTransition.fromStageId / toStageId
  @@index([companyId])
  @@index([workflowId, sortOrder])
  @@index([companyId, isActive])
  // Raw SQL: UNIQUE ("companyId", "id") → FK target for StageAssigneeRule and ServiceRequest.currentStageId
  // Raw SQL: FK (companyId, workflowId) → Workflow(companyId, id)
  // Raw SQL: UNIQUE INDEX ON ("workflowId") WHERE isInitial = true
}

// ── STAGE TRANSITIONS ─────────────────────────────────────────────────────
// Defines legal state machine edges. A Request can only advance via a declared transition.
// fromStageId and toStageId are DB-enforced to belong to the declared workflowId
// via composite FKs (workflowId, fromStageId) and (workflowId, toStageId) in raw SQL.
// The initial stage has no inbound transitions; requests are placed there at creation.
// Deferred: StageTransitionAllowedRole for per-role transition restrictions.

model StageTransition {
  id               String   @id @default(cuid())
  companyId        String   // denormalized; composite FK → Workflow(companyId, id)
  workflowId       String
  fromStageId      String
  toStageId        String
  requiresApproval Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  company   Company       @relation(fields: [companyId], references: [id])
  workflow  Workflow      @relation(fields: [workflowId], references: [id])
  fromStage WorkflowStage @relation("TransitionFrom", fields: [fromStageId], references: [id])
  toStage   WorkflowStage @relation("TransitionTo", fields: [toStageId], references: [id])

  @@unique([workflowId, fromStageId, toStageId])
  @@index([companyId])
  @@index([workflowId, fromStageId]) // hot path: resolve valid next stages for a request
  // Raw SQL: FK (companyId, workflowId) → Workflow(companyId, id)
  // Raw SQL: FK (workflowId, fromStageId) → WorkflowStage(workflowId, id)
  // Raw SQL: FK (workflowId, toStageId) → WorkflowStage(workflowId, id)
}

// ── STAGE ASSIGNEE RULES ──────────────────────────────────────────────────
// References CompanyMembership, not raw User — enforces tenant-scoped assignment.
// ROLE: any active membership with the given role.
// USER: a specific membership; membershipId must be set.
// ROUND_ROBIN: pool-based rotation; state tracked in RoundRobinCursor child record.
// MANUAL: no auto-assignment; membershipId must be null.
// Composite FK (companyId, stageId) → WorkflowStage(companyId, id) via raw SQL.

model StageAssigneeRule {
  id             String         @id @default(cuid())
  companyId      String         // composite FK enforces stage belongs to same company
  stageId        String
  assignmentType AssignmentType
  role           Role?          // set only when assignmentType = ROLE
  membershipId   String?        // set only when assignmentType = USER
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  company          Company            @relation(fields: [companyId], references: [id])
  stage            WorkflowStage      @relation(fields: [stageId], references: [id])
  membership       CompanyMembership? @relation(fields: [membershipId], references: [id])
  roundRobinCursor RoundRobinCursor?

  @@index([companyId])
  @@index([companyId, stageId])
  @@index([membershipId])
  // Raw SQL: FK (companyId, stageId) → WorkflowStage(companyId, id)
}

// ── ROUND ROBIN CURSOR ────────────────────────────────────────────────────
// Persistent assignment state for ROUND_ROBIN rules.
// Must be updated with SELECT FOR UPDATE inside the assignment transaction
// to prevent concurrent calls from reading the same cursor state.
// lastMembershipId = null → no assignment made yet; start from first active member.
// If lastMembershipId references a deactivated membership:
//   resolver treats it as position -1 and restarts from the first active member.
// If the eligible pool is empty: log warning, fall back to MANUAL, do not throw.

model RoundRobinCursor {
  id               String    @id @default(cuid())
  companyId        String
  ruleId           String    @unique
  lastMembershipId String?
  updatedAt        DateTime  @updatedAt

  company    Company            @relation(fields: [companyId], references: [id])
  rule       StageAssigneeRule  @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  membership CompanyMembership? @relation(fields: [lastMembershipId], references: [id])

  @@index([companyId])
}

// ── PERMISSIONS: RESOURCE LEVEL (Layer A) ────────────────────────────────
// System defaults are hardcoded in SYSTEM_DEFAULTS (PermissionResolverService).
// DB tables store company-specific overrides only.
// Resolution: UserPermissionOverride > RolePermission > SYSTEM_DEFAULTS

model RolePermission {
  id        String           @id @default(cuid())
  companyId String
  role      Role
  resource  CompanyResource
  action    PermissionAction
  allowed   Boolean
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, role, resource, action])
  @@index([companyId, role])
}

model UserPermissionOverride {
  id           String           @id @default(cuid())
  companyId    String
  membershipId String           // CompanyMembership, not raw userId
  resource     CompanyResource
  action       PermissionAction
  allowed      Boolean
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  company    Company           @relation(fields: [companyId], references: [id])
  membership CompanyMembership @relation(fields: [membershipId], references: [id])

  @@unique([companyId, membershipId, resource, action])
  @@index([companyId, membershipId])
}

// ── PERMISSIONS: FIELD LEVEL (Layer B) ───────────────────────────────────
// Enforced by FieldFilterInterceptor using SENSITIVE_FIELD_REGISTRY.
// Resolution: UserFieldPermissionOverride > RoleFieldPermission > FIELD_DEFAULTS

model RoleFieldPermission {
  id        String         @id @default(cuid())
  companyId String
  role      Role
  field     SensitiveField
  allowed   Boolean
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, role, field])
  @@index([companyId, role])
}

model UserFieldPermissionOverride {
  id           String         @id @default(cuid())
  companyId    String
  membershipId String
  field        SensitiveField
  allowed      Boolean
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  company    Company           @relation(fields: [companyId], references: [id])
  membership CompanyMembership @relation(fields: [membershipId], references: [id])

  @@unique([companyId, membershipId, field])
  @@index([companyId, membershipId])
}

// ── CONFIGURATION AUDIT LOG ───────────────────────────────────────────────
// Append-only. Written within the same Prisma transaction as the config change.
// actorId references global User (not membershipId) so records survive membership removal.
// Deferred: PARTITION BY RANGE (createdAt) when rows exceed 1M per tenant.

model ConfigAuditLog {
  id         String         @id @default(cuid())
  companyId  String
  actorId    String         // global userId
  operation  AuditOperation
  entityType String         // "WorkflowStage", "AutomationRule", etc.
  entityId   String
  entityCode String?        // stable code for human-readable audit UIs
  before     Json?          // snapshot before change; null for CREATE
  after      Json?          // snapshot after change; null for DELETE
  createdAt  DateTime       @default(now())

  company Company @relation(fields: [companyId], references: [id])
  actor   User    @relation(fields: [actorId], references: [id])

  @@index([companyId])
  @@index([companyId, entityType, entityId])
  @@index([companyId, actorId])
  @@index([companyId, createdAt])
}

// ═══════════════════════════════════════════════════════════════════════════
// SERVICE-REQUESTS BOUNDED CONTEXT
// ═══════════════════════════════════════════════════════════════════════════

// ── SERVICE REQUESTS ──────────────────────────────────────────────────────
// number: sequential per company. Generated via pg_advisory_xact_lock inside
// the creation transaction — see ServiceRequestsService.createServiceRequest.
// workflowId: denormalized at creation; immutable after creation.
// isCancelled: out-of-band terminal flag; does not go through stage machine.
// clientId: nullable; FK → Client when that module is implemented.
// UNIQUE("companyId","id"): FK target for child tables via raw SQL.

model ServiceRequest {
  id                    String    @id @default(cuid())
  companyId             String
  number                Int
  serviceTypeId         String
  workflowId            String
  currentStageId        String
  clientId              String?
  title                 String
  description           String?
  assignedMembershipId  String?
  isCancelled           Boolean   @default(false)
  cancellationReason    String?
  createdByMembershipId String
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  company              Company              @relation(fields: [companyId], references: [id])
  serviceType          ServiceType          @relation(fields: [serviceTypeId], references: [id])
  workflow             Workflow             @relation(fields: [workflowId], references: [id])
  currentStage         WorkflowStage        @relation("ServiceRequestCurrentStage", fields: [currentStageId], references: [id])
  assignedMembership   CompanyMembership?   @relation("RequestAssignee", fields: [assignedMembershipId], references: [id])
  createdByMembership  CompanyMembership    @relation("RequestCreator", fields: [createdByMembershipId], references: [id])
  client               Client?              @relation(fields: [clientId], references: [id])
  fieldValues          RequestFieldValue[]
  stageHistory         RequestStageHistory[]
  assignments          RequestAssignment[]
  tasks                Task[]
  proposals            Proposal[]

  @@unique([companyId, number])
  @@index([companyId])
  @@index([companyId, currentStageId])
  @@index([companyId, serviceTypeId])
  @@index([companyId, clientId])
  @@index([companyId, assignedMembershipId])
  @@index([companyId, isCancelled])
  @@index([companyId, createdAt])
  @@index([companyId, createdByMembershipId])
  // Raw SQL: UNIQUE ("companyId","id") → FK target for child tables
  // Raw SQL: FK (companyId, serviceTypeId) → ServiceType(companyId, id)
  // Raw SQL: FK (companyId, workflowId) → Workflow(companyId, id)
  // Raw SQL: FK (companyId, currentStageId) → WorkflowStage(companyId, id)
  // Raw SQL: FK (companyId, clientId) → Client(companyId, id)
}

// ── REQUEST FIELD VALUES ──────────────────────────────────────────────────
// Typed columns per value kind. JSON avoided: values must be queryable,
// type-safe, and migration-safe when field types are audited.
// valueMulti: String[] for MULTISELECT; other types use their own column.
// Composite FKs via raw SQL enforce cross-table tenant consistency.

model RequestFieldValue {
  id            String    @id @default(cuid())
  companyId     String
  requestId     String
  customFieldId String
  valueText     String?
  valueNumber   Decimal?
  valueBoolean  Boolean?
  valueDate     DateTime?
  valueMulti    String[]

  company     Company        @relation(fields: [companyId], references: [id])
  request     ServiceRequest @relation(fields: [requestId], references: [id])
  customField CustomField    @relation(fields: [customFieldId], references: [id])

  @@unique([requestId, customFieldId])
  @@index([companyId, requestId])
  @@index([customFieldId])
  // Raw SQL: FK (companyId, requestId) → ServiceRequest(companyId, id) ON DELETE CASCADE
  // Raw SQL: FK (companyId, customFieldId) → CustomField(companyId, id) ON DELETE RESTRICT
}

// ── REQUEST STAGE HISTORY ─────────────────────────────────────────────────
// Append-only. fromStageId = null on initial placement.
// This IS the stage audit — no separate ConfigAuditLog entry needed for transitions.
// actorMembershipId references CompanyMembership so history survives userId changes.

model RequestStageHistory {
  id                String   @id @default(cuid())
  companyId         String
  requestId         String
  fromStageId       String?
  toStageId         String
  actorMembershipId String
  note              String?
  createdAt         DateTime @default(now())

  company         Company           @relation(fields: [companyId], references: [id])
  request         ServiceRequest    @relation(fields: [requestId], references: [id])
  fromStage       WorkflowStage?    @relation("StageHistoryFrom", fields: [fromStageId], references: [id])
  toStage         WorkflowStage     @relation("StageHistoryTo", fields: [toStageId], references: [id])
  actorMembership CompanyMembership @relation("StageHistoryActor", fields: [actorMembershipId], references: [id])

  @@index([companyId, requestId])
  @@index([companyId, requestId, createdAt])
  // Raw SQL: FK (companyId, requestId) → ServiceRequest(companyId, id) ON DELETE CASCADE
}

// ── REQUEST ASSIGNMENTS ───────────────────────────────────────────────────
// Append-only assignment log. Current assignee is ServiceRequest.assignedMembershipId.
// Provides full assignment history for audit and timeline UI.

model RequestAssignment {
  id                     String   @id @default(cuid())
  companyId              String
  requestId              String
  membershipId           String
  assignedByMembershipId String
  createdAt              DateTime @default(now())

  company              Company           @relation(fields: [companyId], references: [id])
  request              ServiceRequest    @relation(fields: [requestId], references: [id])
  membership           CompanyMembership @relation("AssignmentTarget", fields: [membershipId], references: [id])
  assignedByMembership CompanyMembership @relation("AssignmentActor", fields: [assignedByMembershipId], references: [id])

  @@index([companyId, requestId])
  @@index([companyId, membershipId])
  // Raw SQL: FK (companyId, requestId) → ServiceRequest(companyId, id) ON DELETE CASCADE
}

// ═══════════════════════════════════════════════════════════════════════════
// CLIENTS BOUNDED CONTEXT
// ═══════════════════════════════════════════════════════════════════════════

// ── CLIENT ───────────────────────────────────────────────────────────────
// type: immutable after creation. Drives display-name semantics and fiscal
//   field applicability.
//
// name: maintained display name. Computed and stored by the service:
//   INDIVIDUAL → provided full name
//   BUSINESS   → tradeName (if set) else legalName
//   Enables fast sort/search without runtime joins.
//
// taxId: nullable; company-scoped partial unique index enforces one-per-company
//   when set. Format validated at DTO layer (CPF=11 digits, CNPJ=14 digits).
//
// number: sequential per company, generated via pg_advisory_xact_lock.
//
// UNIQUE("companyId","id"): FK target for ServiceRequest and ClientFieldValue
//   via raw SQL composite foreign keys.

model Client {
  id                    String     @id @default(cuid())
  companyId             String
  number                Int        // sequential per company
  type                  ClientType // immutable after creation
  name                  String     // display name: full name (PF) or tradeName ?? legalName (PJ)
  email                 String?
  phone                 String?
  notes                 String?
  isActive              Boolean    @default(true)

  // INDIVIDUAL only
  dateOfBirth           DateTime?

  // BUSINESS only
  legalName             String?    // razão social; required when type = BUSINESS (DB CHECK via raw SQL)
  tradeName             String?    // nome fantasia; when set, name is derived from this
  stateRegistration     String?    // IE
  municipalRegistration String?    // IM

  // Shared fiscal document (CPF for PF, CNPJ for PJ)
  taxId                 String?

  // Flat address — mirrors Company model convention
  addressStreet         String?
  addressNumber         String?
  addressComplement     String?
  addressNeighborhood   String?
  addressCity           String?
  addressState          String?    // 2-char state code
  addressPostalCode     String?
  addressCountry        String?    @default("BR")

  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  company         Company            @relation(fields: [companyId], references: [id])
  serviceRequests ServiceRequest[]
  fieldValues     ClientFieldValue[]
  proposals       Proposal[]

  @@unique([companyId, number])
  @@index([companyId])
  @@index([companyId, type])
  @@index([companyId, isActive])
  @@index([companyId, name])
  // Raw SQL: UNIQUE ("companyId","id") → FK target for ServiceRequest and ClientFieldValue
  // Raw SQL: UNIQUE ("companyId","taxId") WHERE "taxId" IS NOT NULL → one taxId per company
  // Raw SQL: CHECK (type != 'BUSINESS' OR "legalName" IS NOT NULL)
}

// ── CLIENT FIELD VALUES ───────────────────────────────────────────────────
// Mirrors RequestFieldValue. Typed columns per value kind.
// CLIENT fields are not service-type-scoped (CustomField.serviceTypeId = null
// for CLIENT target fields is the expected pattern).
// Composite FKs via raw SQL enforce cross-table tenant consistency.

model ClientFieldValue {
  id            String    @id @default(cuid())
  companyId     String
  clientId      String
  customFieldId String
  valueText     String?
  valueNumber   Decimal?
  valueBoolean  Boolean?
  valueDate     DateTime?
  valueMulti    String[]

  company     Company     @relation(fields: [companyId], references: [id])
  client      Client      @relation(fields: [clientId], references: [id])
  customField CustomField @relation(fields: [customFieldId], references: [id])

  @@unique([clientId, customFieldId])
  @@index([companyId, clientId])
  @@index([customFieldId])
  // Raw SQL: FK (companyId, clientId) → Client(companyId, id) ON DELETE CASCADE
  // Raw SQL: FK (companyId, customFieldId) → CustomField(companyId, id) ON DELETE RESTRICT
}

// ═══════════════════════════════════════════════════════════════════════════
// TASKS BOUNDED CONTEXT
// ═══════════════════════════════════════════════════════════════════════════

// ── TASK ──────────────────────────────────────────────────────────────────
// Always linked to a ServiceRequest (mandatory, not optional).
// number: sequential per company — generated via pg_advisory_xact_lock with
//   the ':tasks' namespace to avoid contention with request/client generators.
// status: flat enum state machine. Not configurable — tasks are too simple to
//   justify a workflow stage graph.
// completedAt / cancelledAt: set atomically inside the transition transaction.
// UNIQUE("companyId","id"): FK target for TaskComment via raw SQL.
// Composite FK (companyId, requestId) → ServiceRequest(companyId, id) via raw SQL
//   with ON DELETE RESTRICT so requests with open tasks cannot be silently removed.

model Task {
  id                    String       @id @default(cuid())
  companyId             String
  requestId             String
  number                Int          // sequential per company
  status                TaskStatus   @default(OPEN)
  priority              TaskPriority @default(NORMAL)
  title                 String
  description           String?
  assignedMembershipId  String?
  createdByMembershipId String
  dueAt                 DateTime?
  completedAt           DateTime?    // set when status → DONE; cleared on reopen
  cancelledAt           DateTime?    // set when status → CANCELLED
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  company             Company            @relation(fields: [companyId], references: [id])
  request             ServiceRequest     @relation(fields: [requestId], references: [id])
  assignedMembership  CompanyMembership? @relation("TaskAssignee", fields: [assignedMembershipId], references: [id])
  createdByMembership CompanyMembership  @relation("TaskCreator", fields: [createdByMembershipId], references: [id])
  comments            TaskComment[]

  @@unique([companyId, number])
  @@index([companyId])
  @@index([companyId, requestId])
  @@index([companyId, status])
  @@index([companyId, assignedMembershipId])
  @@index([companyId, dueAt])
  @@index([companyId, createdAt])
  // Raw SQL: UNIQUE ("companyId", "id") → FK target for TaskComment
  // Raw SQL: FK (companyId, requestId) → ServiceRequest(companyId, id) ON DELETE RESTRICT
}

// ── TASK COMMENT ──────────────────────────────────────────────────────────
// Append-only operational notes. Distinct from Chat (channel-based conversations).
// Deletion: author may delete own comment; OWNER/ADMIN may delete any comment.
// Composite FK (companyId, taskId) → Task(companyId, id) via raw SQL ON DELETE CASCADE
// so comments are removed atomically when a task is deleted.

model TaskComment {
  id                 String   @id @default(cuid())
  companyId          String
  taskId             String
  authorMembershipId String
  body               String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  company          Company           @relation(fields: [companyId], references: [id])
  task             Task              @relation(fields: [taskId], references: [id])
  authorMembership CompanyMembership @relation("TaskCommentAuthor", fields: [authorMembershipId], references: [id])

  @@index([companyId, taskId])
  @@index([companyId, taskId, createdAt])
  // Raw SQL: FK (companyId, taskId) → Task(companyId, id) ON DELETE CASCADE
}

// ═══════════════════════════════════════════════════════════════════════════
// PROPOSALS BOUNDED CONTEXT
// ═══════════════════════════════════════════════════════════════════════════

// ── PROPOSAL ──────────────────────────────────────────────────────────────
// Always linked to a ServiceRequest (mandatory, non-nullable, immutable).
// clientId: derived from request.clientId at creation time. Stored on the
//   proposal independently so the client anchor survives future request edits.
//   Nullable when the request had no client at proposal creation time.
// number: sequential per company. Generated via pg_advisory_xact_lock with
//   'proposals:' namespace to avoid contention with request/client/task generators.
// status: enforced by ProposalTransitionsService state machine.
//   Terminal states: APPROVED, REJECTED, EXPIRED, CANCELLED.
// totalCost: sum of (item.internalCost × item.quantity). PRIVILEGED only.
//   Stripped by FieldFilterInterceptor via SensitiveField.INTERNAL_COST.
// discountPct / discountAmount: mutual exclusion enforced by service.
//   If discountPct is set, effectiveDiscount = subtotal × pct / 100.
//   If discountAmount is set, it is used directly.
//   totalPrice = subtotal − effectiveDiscount. Recomputed on every item change.
// UNIQUE(companyId, id): FK target for child tables via raw SQL.
// Partial unique index WHERE status='APPROVED' ON (serviceRequestId): at most
//   one approved proposal per request. Service catches P2002 from this index.

model Proposal {
  id                     String         @id @default(cuid())
  companyId              String
  serviceRequestId       String
  clientId               String?
  number                 Int
  status                 ProposalStatus @default(DRAFT)
  title                  String
  notes                  String?        // internal; excluded from CLIENT response projection
  clientNotes            String?        // external-facing; shown on PDF and client portal
  discountPct            Decimal?       @db.Decimal(5, 2)
  discountAmount         Decimal?       @db.Decimal(12, 2)
  subtotal               Decimal        @default(0)  @db.Decimal(12, 2)
  totalPrice             Decimal        @default(0)  @db.Decimal(12, 2)
  totalCost              Decimal        @default(0)  @db.Decimal(12, 2)
  validUntil             DateTime?
  pdfUrl                 String?
  pdfGeneratedAt         DateTime?
  sentAt                 DateTime?
  approvedAt             DateTime?
  rejectedAt             DateTime?
  expiredAt              DateTime?
  cancelledAt            DateTime?
  rejectionReason        String?
  cancellationReason     String?
  approvedByMembershipId String?
  rejectedByMembershipId String?
  createdByMembershipId  String
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  company              Company               @relation(fields: [companyId], references: [id])
  serviceRequest       ServiceRequest        @relation(fields: [serviceRequestId], references: [id])
  client               Client?               @relation(fields: [clientId], references: [id])
  createdByMembership  CompanyMembership     @relation("ProposalCreator", fields: [createdByMembershipId], references: [id])
  approvedByMembership CompanyMembership?    @relation("ProposalApprover", fields: [approvedByMembershipId], references: [id])
  rejectedByMembership CompanyMembership?    @relation("ProposalRejector", fields: [rejectedByMembershipId], references: [id])
  items                ProposalItem[]
  statusHistory        ProposalStatusHistory[]
  fieldValues          ProposalFieldValue[]

  @@unique([companyId, number])
  @@index([companyId])
  @@index([companyId, serviceRequestId])
  @@index([companyId, clientId])
  @@index([companyId, status])
  @@index([companyId, validUntil])
  @@index([companyId, createdAt])
  // Raw SQL: UNIQUE ("companyId", "id") → FK target for child tables
  // Raw SQL: FK (companyId, serviceRequestId) → ServiceRequest(companyId, id) ON DELETE RESTRICT
  // Raw SQL: FK (companyId, clientId) → Client(companyId, id) — nullable, ON DELETE RESTRICT
  // Raw SQL: CREATE UNIQUE INDEX udx_one_approved_proposal_per_request ON "Proposal" ("serviceRequestId") WHERE status = 'APPROVED'
}

// ── PROPOSAL ITEM ─────────────────────────────────────────────────────────
// Line items for a Proposal. Mutable only when Proposal.status = DRAFT.
// subtotal: stored computed value = quantity × unitPrice × (1 − discountPct/100).
//   Recomputed by ProposalItemsService on every add/update/remove mutation.
// internalCost: unit cost for this line (e.g. supplier price).
//   PRIVILEGED only. Stripped by FieldFilterInterceptor (INTERNAL_COST).
// Proposal.totalCost = SUM(item.internalCost × item.quantity).
// Cascade delete: removing the parent Proposal removes all its items.

model ProposalItem {
  id           String   @id @default(cuid())
  companyId    String
  proposalId   String
  description  String
  unit         String?
  quantity     Decimal  @db.Decimal(12, 4)
  unitPrice    Decimal  @db.Decimal(12, 2)
  discountPct  Decimal? @db.Decimal(5, 2)
  internalCost Decimal? @db.Decimal(12, 2)
  subtotal     Decimal  @db.Decimal(12, 2)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company  Company  @relation(fields: [companyId], references: [id])
  proposal Proposal @relation(fields: [proposalId], references: [id])

  @@index([companyId, proposalId])
  @@index([companyId, proposalId, sortOrder])
  // Raw SQL: FK (companyId, proposalId) → Proposal(companyId, id) ON DELETE CASCADE
}

// ── PROPOSAL STATUS HISTORY ───────────────────────────────────────────────
// Append-only. fromStatus = null on initial DRAFT placement.
// Written within the same transaction as every status change.
// Mirrors RequestStageHistory for operational consistency.

model ProposalStatusHistory {
  id                String          @id @default(cuid())
  companyId         String
  proposalId        String
  fromStatus        ProposalStatus?
  toStatus          ProposalStatus
  actorMembershipId String
  note              String?
  createdAt         DateTime        @default(now())

  company         Company           @relation(fields: [companyId], references: [id])
  proposal        Proposal          @relation(fields: [proposalId], references: [id])
  actorMembership CompanyMembership @relation("ProposalStatusHistoryActor", fields: [actorMembershipId], references: [id])

  @@index([companyId, proposalId])
  @@index([companyId, proposalId, createdAt])
  // Raw SQL: FK (companyId, proposalId) → Proposal(companyId, id) ON DELETE CASCADE
}

// ── PROPOSAL FIELD VALUES ─────────────────────────────────────────────────
// Custom fields with target = PROPOSAL. Not service-type-scoped.
// Mirrors RequestFieldValue and ClientFieldValue for consistency.
// Mutable only when Proposal.status = DRAFT.

model ProposalFieldValue {
  id            String    @id @default(cuid())
  companyId     String
  proposalId    String
  customFieldId String
  valueText     String?
  valueNumber   Decimal?
  valueBoolean  Boolean?
  valueDate     DateTime?
  valueMulti    String[]

  company     Company     @relation(fields: [companyId], references: [id])
  proposal    Proposal    @relation(fields: [proposalId], references: [id])
  customField CustomField @relation(fields: [customFieldId], references: [id])

  @@unique([proposalId, customFieldId])
  @@index([companyId, proposalId])
  @@index([customFieldId])
  // Raw SQL: FK (companyId, proposalId) → Proposal(companyId, id) ON DELETE CASCADE
  // Raw SQL: FK (companyId, customFieldId) → CustomField(companyId, id) ON DELETE RESTRICT
}
